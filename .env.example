# Pickleball Haven Booker — Configuration
# Copy this file to .env and fill in your values.

# Your CourtReserve login credentials
COURTRESERVE_EMAIL=your@email.com
COURTRESERVE_PASS=yourpassword

# Your Pickleball Haven membership tier: AM, PM, or FULL
# AM   = sessions before 2:30 PM only (default if not set)
# PM   = sessions from 2:30 PM onward only
# FULL = all sessions, no time restriction
MEMBERSHIP_TYPE=AM
